{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".eve/**", ".vercel/output/**"]
    },
    "lint": {},
    "check-types": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}

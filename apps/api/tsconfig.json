{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@zico/tsconfig/base.json",
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["bun"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false
  }
}

# Single root env for the whole monorepo. `cp .env.example .env`, fill in, then
# `bun run dev` loads it and every app (web, api, butler) inherits it.
#
# ─── Eve agent (agents/butler) ────────────────────────────────────────────
# Eve resolves model strings (e.g. "anthropic/claude-sonnet-4.6") through the
# Vercel AI Gateway. For local dev outside Vercel you need a gateway / provider key.
# See https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Optional: use a local OpenAI-compatible provider (e.g. LM Studio) instead of
# the Vercel AI Gateway for fully-offline dev. Wire these in agents/butler/agent/agent.ts.
# LMSTUDIO_API_KEY=lmstudio
# LMSTUDIO_BASE_URL=http://192.168.12.15:1234/v1

# ─── Web app (apps/web) ───────────────────────────────────────────────────
# URL of the zico API gateway that the web chat proxy forwards to. The gateway
# (not the web app) routes on to the agent.
API_URL=http://127.0.0.1:8787

# ─── API gateway (apps/api) ───────────────────────────────────────────────
# URL of the running Eve agent that the gateway proxies /agents/butler/* to.
AGENT_URL=http://127.0.0.1:3001

# ─── Discord channel (agents/butler) ──────────────────────────────────────
# Discord app credentials for the butler's Discord Interactions endpoint,
# proxied at /agents/butler/v1/discord. From the Discord Developer Portal.
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
# Channel ID for deploy notifications (Developer Mode on → right-click channel →
# Copy Channel ID). Reuses DISCORD_BOT_TOKEN; the bot must be in this channel
# with Send Messages permission.
DISCORD_DEPLOY_CHANNEL_ID=

# ─── Supabase (apps/web) — auth, preferences, sessions, chat history ───────
# From the Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never exposed to the browser. Used for privileged backend writes.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Observability (OpenTelemetry → Braintrust) ───────────────────────────
# Shared by web, api, and agents. https://www.braintrust.dev/app/settings/api-keys
BRAINTRUST_API_KEY=
# BRAINTRUST_API_URL=https://api-eu.braintrust.dev   # EU data plane only

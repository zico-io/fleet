{
  "name": "zico",
  "version": "0.0.0",
  "private": true,
  "description": "zico — a personal agent system (Eve agents + Next.js web app)",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "agents/*",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
